---
import BaseHead from '@/components/BaseHead'
import Header from '@/components/Header'
import Footer from '@/components/Footer'
import YaM from '@/components/YaM'
import ProviderTheme from '@/components/ProviderTheme'
import ProviderAnimations from '@/components/ProviderAnimations'
import TwSizeIndicator from '@/components/TwSizeIndicator'
import { ViewTransitions } from 'astro:transitions'
const { title, description, h1, image, articleDate, noindex } = Astro.props
---

<html lang='ru' class='scroll-smooth'>
		<head>
			<!-- Defer CSS to prevent render-blocking -->
			<script is:inline>
				(function(){var o=new MutationObserver(function(){var l=document.querySelectorAll('link[rel="stylesheet"][href*="/_astro/"]:not([data-css-deferred])');for(var i=0;i<l.length;i++){l[i].setAttribute('data-css-deferred','1');l[i].media='print';l[i].onload=function(){this.media='all'}}});o.observe(document.documentElement,{childList:true,subtree:true})})()
			</script>
		<BaseHead title={title} description={description} ogImage={image} articleDate={articleDate} noindex={noindex} />
		<ProviderTheme />
		<ProviderAnimations />
		<ViewTransitions />
		<meta name='yandex-verification' content='edfa58d760f1a977' />
		<YaM />
		<slot name='head' />
	</head>

	<body class='bg-white text-stone-950 dark:bg-gray-800 dark:text-white'>
		<main class='sm:mx-autoantialiased grid gap-12 overflow-hidden md:overflow-visible'>
			<Header />
			<slot />
		</main>
				<Footer />
				<TwSizeIndicator />
			</body>
</html>
