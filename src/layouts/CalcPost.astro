---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout'
import Hero from '@/components/Hero'
import { ViewTransitions } from 'astro:transitions'
import AbsolyutnijSpirt from '@/calc/AbsolyutnijSpirt.jsx'
import Braga from '@/calc/Braga.jsx'
import DrobnayaPeregonka from '@/calc/DrobnayaPeregonka.jsx'
import OtborGolov from '@/calc/OtborGolov.jsx'
import PoslePervoj from '@/calc/PoslePervoj.jsx'
import RazbavleniyaSamogona from '@/calc/RazbavleniyaSamogona.jsx'
import SebestoimApprox from '@/calc/SebestoimApprox.jsx'
import Sebestoimost from '@/calc/Sebestoimost.jsx'
import SmeshSpirt from '@/calc/SmeshSpirt.jsx'
import Temperature from '@/calc/Temperature.jsx'
import VodkaCalc from '@/calc/VodkaCalc.jsx'
import Zamena from '@/calc/Zamena.jsx'
import Breadcrumbs from '@/components/Breadcrumbs'
import SubscribeTelegram from '@/components/SubscribeTelegram'
import JsonLD from '@/components/JsonLD'

type Props = {
	id: CollectionEntry<'calcs'>['id']
	data: CollectionEntry<'calcs'>['data']
}

const { data, id } = Astro.props
const { title, description, h1, heroImage, pretext, faq } = data

// Related calculators mapping
const RELATED_CALCS = {
	'kalkulyator-absolyutnogo-spirta': [
		{ slug: 'kalkulyator-saharnoj-bragi', title: 'Калькулятор браги' },
		{ slug: 'kalkulyator-otbor-golov', title: 'Калькулятор отбора голов' },
		{ slug: 'kalkulyator-drobnoj-peregonki', title: 'Дробная перегонка' },
	],
	'kalkulyator-drobnoj-peregonki': [
		{ slug: 'kalkulyator-otbor-golov', title: 'Калькулятор отбора голов' },
		{ slug: 'razbavlenie-samogona-vodoj-posle-pervoj-peregonki', title: 'Разбавление после первого перегона' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
	],
	'kalkulyator-otbor-golov': [
		{ slug: 'kalkulyator-drobnoj-peregonki', title: 'Дробная перегонка' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
		{ slug: 'kalkulyator-razbavleniya-samogona-vodoj', title: 'Разбавление самогона' },
	],
	'kalkulyator-razbavleniya-samogona-vodoj': [
		{ slug: 'kalkulyator-vodki-iz-spirta', title: 'Калькулятор водки' },
		{ slug: 'razbavlenie-samogona-vodoj-posle-pervoj-peregonki', title: 'Разбавление после первого перегона' },
		{ slug: 'kalkulyator-spirta-ot-temperatury', title: 'Спирт от температуры' },
	],
	'kalkulyator-saharnoj-bragi': [
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
		{ slug: 'kalkulyator-sebestoimosti-samogona', title: 'Себестоимость самогона' },
		{ slug: 'kalkulyator-zameny-sahara-glyukozoj', title: 'Замена сахара декстрозой' },
	],
	'kalkulyator-sebestoimosti-samogona': [
		{ slug: 'primernaya-stoimost-samogona', title: 'Примерная стоимость' },
		{ slug: 'kalkulyator-saharnoj-bragi', title: 'Калькулятор браги' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
	],
	'kalkulyator-smeshivaniya-spirtov': [
		{ slug: 'kalkulyator-razbavleniya-samogona-vodoj', title: 'Разбавление самогона' },
		{ slug: 'kalkulyator-vodki-iz-spirta', title: 'Калькулятор водки' },
		{ slug: 'kalkulyator-spirta-ot-temperatury', title: 'Спирт от температуры' },
	],
	'kalkulyator-spirta-ot-temperatury': [
		{ slug: 'kalkulyator-razbavleniya-samogona-vodoj', title: 'Разбавление самогона' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
		{ slug: 'kalkulyator-smeshivaniya-spirtov', title: 'Смешивание спиртов' },
	],
	'kalkulyator-vodki-iz-spirta': [
		{ slug: 'kalkulyator-razbavleniya-samogona-vodoj', title: 'Разбавление самогона' },
		{ slug: 'kalkulyator-smeshivaniya-spirtov', title: 'Смешивание спиртов' },
		{ slug: 'kalkulyator-spirta-ot-temperatury', title: 'Спирт от температуры' },
	],
	'kalkulyator-zameny-sahara-glyukozoj': [
		{ slug: 'kalkulyator-saharnoj-bragi', title: 'Калькулятор браги' },
		{ slug: 'kalkulyator-sebestoimosti-samogona', title: 'Себестоимость самогона' },
		{ slug: 'primernaya-stoimost-samogona', title: 'Примерная стоимость' },
	],
	'primernaya-stoimost-samogona': [
		{ slug: 'kalkulyator-sebestoimosti-samogona', title: 'Себестоимость самогона' },
		{ slug: 'kalkulyator-saharnoj-bragi', title: 'Калькулятор браги' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
	],
	'razbavlenie-samogona-vodoj-posle-pervoj-peregonki': [
		{ slug: 'kalkulyator-drobnoj-peregonki', title: 'Дробная перегонка' },
		{ slug: 'kalkulyator-razbavleniya-samogona-vodoj', title: 'Разбавление самогона' },
		{ slug: 'kalkulyator-absolyutnogo-spirta', title: 'Абсолютный спирт' },
	],
}
const relatedLinks = RELATED_CALCS[id.replace('calcs/', '').replace('.mdx', '')] || []
---

<BaseLayout title={title} description={description} image={heroImage?.src}>
		<JsonLD
			type='WebApplication'
			data={{
				name: title,
				url: `https://samogoncalc.ru/${id}/`,
				description: description,
				applicationCategory: 'CalculatorApplication',
				operatingSystem: 'All',
				offers: { '@type': 'Offer', price: '0', priceCurrency: 'RUB' }
			}}
			slot='head'
		/>
		{faq && faq.length > 0 && (
			<JsonLD
				type='FAQPage'
				data={{
					mainEntity: faq.map((item: { q: string; a: string }) => ({
						'@type': 'Question',
						name: item.q,
						acceptedAnswer: {
							'@type': 'Answer',
							text: item.a
						}
					}))
				}}
				slot='head'
			/>
		)}
	<Hero headImg={heroImage} titlePage={title} h1={h1} descriptionPage={description} urlSeo={id} />

	<Breadcrumbs
		items={[
			{ label: 'Главная', href: '/' },
			{ label: title }
		]}
	/>

	<div class='mx-auto max-w-[680px] pt-12 text-lg px-6'>
		{pretext}
	</div>

	<div class='mx-auto w-full max-w-6xl text-lg sm:px-6 px-6'>
			{
				title == 'Калькулятор абсолютного спирта: формула + как рассчитать' ? (
					<AbsolyutnijSpirt client:load />
				) : title == 'Калькулятор браги (выход сахарной и зерновой браги)' ? (
					<Braga client:load />
				) : title == 'Калькулятор второй дробной перегонки самогона (спирта-сырца)' ? (
					<DrobnayaPeregonka client:load />
				) : title == 'Калькулятор отбора голов при второй перегонке' ? (
					<OtborGolov client:load />
				) : title == 'Калькулятор разбавления спирта-сырца (после первого перегона)' ? (
					<PoslePervoj client:load />
				) : title == 'Калькулятор разбавления самогона и спирта' ? (
					<RazbavleniyaSamogona client:load />
				) : title == 'Калькулятор примерной стоимости самогона' ? (
					<SebestoimApprox client:load />
				) : title == 'Себестоимость самогона' ? (
					<Sebestoimost client:load />
				) : title == 'Калькулятор смешивания спиртов' ? (
					<SmeshSpirt client:load />
				) : title == 'Спирт от температуры: Калькулятор' ? (
					<Temperature client:load />
				) : title == 'Калькулятор водки: как разбавить самогон или спирта до 40°' ? (
					<VodkaCalc client:load />
				) : title == 'Калькулятор замены сахара декстрозой' ? (
					<Zamena client:load />
				) : (
					<p>Калькулятор не найден</p>
				)
			}
		</div>
	<article class='min-w-ful md:py-4 sm:max-w-none md:max-w-none'>
		<div>
			<slot />
		</div>
	</article>

	{relatedLinks.length > 0 && (
		<section class='mx-auto max-w-6xl px-6 py-12'>
			<h2 class='text-2xl font-bold text-center mb-8 text-stone-800 dark:text-white'>
				🔗 Связанные калькуляторы
			</h2>
			<div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-3'>
				{relatedLinks.map(link => (
					<a href={`/${link.slug}/`}
						class='block p-5 rounded-xl border border-stone-200 dark:border-stone-700 
						       hover:border-[#1ABC9C] dark:hover:border-[#1ABC9C] 
						       hover:shadow-md transition-all duration-200
						       bg-white dark:bg-gray-800'>
						<span class='text-[#1ABC9C] font-semibold'>{link.title}</span>
					</a>
				))}
			</div>
		</section>
	)}

	<SubscribeTelegram />
</BaseLayout>
