---
// EquipmentWidget.astro — контекстный блок «🛒 Для этого расчёта понадобится»
// Показывает товары, релевантные текущему калькулятору
export interface EquipmentItem {
	name: string
	desc: string
	price: string        // примерная цена, например "от 300 ₽"
	url: string           // партнёрская ссылка (пока заглушка, позже Яндекс.Маркет)
	icon?: string         // emoji-иконка
}

export interface Props {
	title?: string
	items: EquipmentItem[]
	partnerId?: string    // partner_id Яндекс.Маркета
}

const { title = '🛒 Для этого расчёта понадобится', items, partnerId } = Astro.props

if (!items || items.length === 0) return null
---

<section class="mx-auto max-w-6xl px-6 py-10">
	<h2 class="text-2xl font-bold text-center mb-8 text-stone-800 dark:text-white">
		{title}
	</h2>
	<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
		{items.map((item) => (
			<a
				href={item.url}
				target="_blank"
				rel="nofollow sponsored noopener"
				class="group block p-5 rounded-xl border border-stone-200 dark:border-stone-700 
				       hover:border-[#1ABC9C] dark:hover:border-[#1ABC9C] 
				       hover:shadow-md transition-all duration-200
				       bg-white dark:bg-gray-800"
			>
				<div class="flex items-start gap-3 mb-2">
					{item.icon && <span class="text-2xl">{item.icon}</span>}
					<h3 class="font-semibold text-stone-800 dark:text-white group-hover:text-[#1ABC9C] transition-colors">
						{item.name}
					</h3>
				</div>
				<p class="text-sm text-stone-500 dark:text-stone-400 mb-3">{item.desc}</p>
				<div class="flex items-center justify-between">
					<span class="text-sm font-medium text-[#1ABC9C]">{item.price}</span>
					<span class="text-xs text-stone-400 dark:text-stone-500">
						на Яндекс.Маркете →
					</span>
				</div>
			</a>
		))}
	</div>
</section>
