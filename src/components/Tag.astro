---
export interface Props {
	tag: string
}
const { tag } = Astro.props
---

<a href={`/tags/${tag.toLowerCase()}`} aria-label={tag}>
	<span
		class='border-2 border-black dark:border-white font-semibold text-black dark:bg-[#00614B] dark:text-white text-sm w-fit px-3 py-1.5 md:px-5 md:py-2.5 rounded-2xl leading-normal inline-block'
	>
		{tag ?? 'Blog Tag'}
	</span>
</a>
