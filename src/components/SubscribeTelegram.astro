---
// SubscribeTelegram — форма захвата в Telegram-канал
import TgIcon from '@/components/TgIcon'
---

<div class="my-12 mx-auto max-w-3xl px-4">
	<div class="rounded-2xl bg-gradient-to-r from-[#1ABC9C] to-[#0088cc] dark:from-[#00614B] dark:to-[#004080] p-8 text-white text-center shadow-lg">
		<div class="flex justify-center mb-4">
			<div class="rounded-full overflow-hidden w-20 h-20 ring-4 ring-white/30">
				<img src="/ava-samogonco.jpg" alt="Samogonco Telegram" class="w-full h-full object-cover" width="80" height="80" />
			</div>
		</div>
		<h2 class="text-2xl md:text-3xl font-bold mb-3">
			Приобщись к тайным знаниям синих аксакалов&nbsp;в нашем Telegram-канале
		</h2>
		<p class="text-lg mb-2 opacity-90">
			📊 Таблица пропорций разбавления самогона
		</p>
		<p class="text-lg mb-2 opacity-90">
			🍸 5 секретных рецептов настоек
		</p>
		<p class="text-lg mb-6 opacity-90">
			🔥 Лайфхаки и опыт бывалых самогонщиков
		</p>
		<a
			href="tg://resolve?domain=samogonco"
			class="inline-flex items-center gap-2 bg-white text-[#0088cc] font-bold text-lg px-8 py-3 rounded-full hover:bg-gray-100 transition-all hover:scale-105 shadow-md"
		>
			<svg class="tremble" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="#0088cc">
				<path d="M9.417 15.181l-.397 5.584c.568 0 .814-.244 1.109-.537l2.663-2.545 5.518 4.041c1.012.564 1.725.267 1.998-.931l3.622-16.972.001-.001c.321-1.496-.541-2.081-1.527-1.714l-21.29 8.151c-1.453.564-1.431 1.374-.247 1.741l5.443 1.693 12.643-7.911c.595-.394 1.136-.176.691.218z"/>
			</svg>
			Подписаться на Telegram
		</a>
		<p class="text-sm mt-4 opacity-75">
			Уже 1 000+ самогонщиков с нами. Присоединяйся!
		</p>
	</div>
</div>

<style>
	.tremble {
		display: inline-block;
		animation: tremble 0.15s infinite;
	}
	@keyframes tremble {
		0%   { transform: translate(0, 0) rotate(0deg); }
		10%  { transform: translate(-3px, 2px) rotate(-3deg); }
		20%  { transform: translate(3px, -2px) rotate(2deg); }
		30%  { transform: translate(-2px, -3px) rotate(-1deg); }
		40%  { transform: translate(2px, 3px) rotate(3deg); }
		50%  { transform: translate(-3px, -1px) rotate(-2deg); }
		60%  { transform: translate(3px, 1px) rotate(1deg); }
		70%  { transform: translate(-1px, -2px) rotate(-3deg); }
		80%  { transform: translate(1px, 2px) rotate(2deg); }
		90%  { transform: translate(-2px, -1px) rotate(-1deg); }
		100% { transform: translate(0, 0) rotate(0deg); }
	}
	a:hover .tremble {
		animation: tremble-hard 0.08s infinite;
	}
	@keyframes tremble-hard {
		0%   { transform: translate(0, 0) rotate(0deg); }
		10%  { transform: translate(-6px, 4px) rotate(-6deg); }
		20%  { transform: translate(6px, -4px) rotate(4deg); }
		30%  { transform: translate(-4px, -6px) rotate(-2deg); }
		40%  { transform: translate(4px, 6px) rotate(6deg); }
		50%  { transform: translate(-6px, -2px) rotate(-4deg); }
		60%  { transform: translate(6px, 2px) rotate(2deg); }
		70%  { transform: translate(-2px, -4px) rotate(-6deg); }
		80%  { transform: translate(2px, 4px) rotate(4deg); }
		90%  { transform: translate(-4px, -2px) rotate(-2deg); }
		100% { transform: translate(0, 0) rotate(0deg); }
	}
</style>
