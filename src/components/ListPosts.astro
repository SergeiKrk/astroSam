---
import type { CollectionEntry } from 'astro:content'
import PostCard from '@/components/PostCard'
import { cn } from '@/utils'

type Props = {
	posts: CollectionEntry<'blog'>[]
	FirstBig?: boolean
	maxVisible?: number
	containerId?: string
}

const { posts, FirstBig = false, maxVisible, containerId } = Astro.props
---

<section
	id={containerId}
	class={cn(
		`grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3  gap-8 mt-3`,
		FirstBig && `md:[&>*:first-child]:col-span-2`
	)}
>
	{
		posts.map(async (post, i) => {
			const { remarkPluginFrontmatter } = await post.render()
			const hidden = maxVisible && i >= maxVisible

			return (
				<div class={hidden ? 'hidden load-more-item' : 'load-more-item'}>
					{post.data.status && (
						<PostCard
							id={post.id}
							data={post.data}
							slug={post.slug}
							readTime={remarkPluginFrontmatter.minutesRead}
						/>
					)}
				</div>
			)
		})
	}
</section>
