<!-- Yandex.Metrika counter — deferred to after page load -->
<script is:inline>
	// Load Metrika after page is fully loaded to avoid blocking rendering
	function loadMetrika() {
		(function (m, e, t, r, i, k, a) {
			m[i] =
				m[i] ||
				function () {
					;(m[i].a = m[i].a || []).push(arguments)
				}
			m[i].l = 1 * new Date()
			;(k = e.createElement(t)),
				(a = e.getElementsByTagName(t)[0]),
				(k.async = 1),
				(k.fetchpriority = 'low'),
				(k.src = r),
				a.parentNode.insertBefore(k, a)
		})(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym')

		ym(87466855, 'init', {
			clickmap: true,
			trackLinks: true,
			accurateTrackBounce: true
		})

		// Отслеживание партнёрских ссылок на Яндекс.Маркет
		document.addEventListener('click', function(e) {
			var link = e.target.closest('a[href*="market.yandex.ru"]')
			if (!link) return
			var code = (link.href.match(/\/cc\/(\w+)/) || [])[1] || ''
			var isSlider = !!link.closest('.carousel-container')
			var goal = isSlider ? 'partner-slider' : 'partner-link'
			ym(87466855, 'reachGoal', goal, { partner_code: code })
		})
	}

	if (document.readyState === 'complete') {
		// Delay Metrika to avoid long tasks blocking LCP measurement
		setTimeout(loadMetrika, 2000)
	} else {
		window.addEventListener('load', () => setTimeout(loadMetrika, 2000))
	}
</script>
