---
// FaqAccordion.astro — компонент для FAQ в виде аккордеона
// Использует нативный <details>/<summary> — работает без JS, SEO-friendly
//
// Использование:
//   <FaqAccordion items={[
//     { q: "Вопрос?", a: "Ответ в HTML или тексте." },
//   ]} />
//
// a может содержать HTML-разметку (ссылки, списки, <b>)

interface FaqItem {
  q: string
  a: string
}

const { items } = Astro.props as { items: FaqItem[] }
---

<div class='faq-accordion space-y-3 mt-4'>
  {
    items.map((item, index) => (
      <details class='group border border-gray-200 dark:border-gray-600 rounded-lg overflow-hidden transition-all duration-200'>
        <summary class='flex items-center justify-between cursor-pointer px-5 py-4 text-lg font-medium text-gray-800 dark:text-gray-100 bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors select-none'>
          <span>{item.q}</span>
          <svg class='w-5 h-5 text-gray-400 dark:text-gray-300 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-3' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M19 9l-7 7-7-7' />
          </svg>
        </summary>
        <div class='px-5 py-4 text-base text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 leading-relaxed' set:html={item.a} />
      </details>
    ))
  }
</div>
